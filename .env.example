# Copy to .env only when overriding local development defaults.
# .env is ignored by Git; never commit real credentials.
SENTINEL_DB_NAME=sentinel
SENTINEL_DB_USERNAME=sentinel
SENTINEL_DB_PASSWORD=sentinel
SENTINEL_POSTGRES_PORT=55432
SENTINEL_REDIS_PORT=6379
SENTINEL_REDIS_HOST=localhost
SENTINEL_RABBITMQ_HOST=localhost
SENTINEL_RABBITMQ_USERNAME=sentinel
SENTINEL_RABBITMQ_PASSWORD=sentinel
SENTINEL_RABBITMQ_PORT=5672
SENTINEL_RABBITMQ_MANAGEMENT_PORT=15672
